{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/game-studio", "destination": "/", "permanent": true },
    { "source": "/games", "destination": "/", "permanent": true },
    { "source": "/einspruch", "destination": "https://einspruch.architect-dna.ch", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/wg/set", "destination": "/api/wg/set.js" },
    { "source": "/api/wg/get", "destination": "/api/wg/get.js" },
    { "source": "/api/reach", "destination": "/api/reach/index.js" },
    { "source": "/api/brief", "destination": "/api/brief/index.js" },
    { "source": "/api/concepts/get", "destination": "/api/concepts/get.js" },
    { "source": "/api/concepts/save", "destination": "/api/concepts/save.js" },
    { "source": "/", "has": [{"type": "host", "value": "clyedo.architect-dna.ch"}], "destination": "/clyedo/app.html" },
    { "source": "/", "has": [{"type": "host", "value": "calm.architect-dna.ch"}], "destination": "/calm/app.html" },
    { "source": "/", "has": [{"type": "host", "value": "gridfal.architect-dna.ch"}], "destination": "/gridfal/play.html" },
    { "source": "/", "has": [{"type": "host", "value": "mission.architect-dna.ch"}], "destination": "/velo-noir" },
    { "source": "/", "has": [{"type": "host", "value": "sprint.architect-dna.ch"}], "destination": "/sprint/play.html" },
    { "source": "/", "has": [{"type": "host", "value": "fly.architect-dna.ch"}], "destination": "/fly/play.html" }
  ]
}
